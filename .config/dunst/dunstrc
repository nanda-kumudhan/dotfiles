[global]
    monitor = 0
    follow = mouse

    width = 320
    origin = top-right
    offset = 12x12

    notification_limit = 5

    frame_width = 2
    frame_color = "#4a4a4a"

    gap_size = 6
    padding = 10

    horizontal_padding = 10
    vertical_padding = 8

    font = JetBrainsMono Nerd Font 10

    icon_position = left
    min_icon_size = 32
    max_icon_size = 64

    markup = full
    plain_text = no

    format = "<b>%s</b>\n%b"

    alignment = left
    vertical_alignment = center

    show_age_threshold = 60
    word_wrap = yes
    ellipsize = middle

    ignore_newline = no

    stack_duplicates = true
    hide_duplicate_count = false

    idle_threshold = 120

    separator_height = 2
    separator_color = frame

    background = "#000000"
    foreground = "#e6e6e6"

    timeout = 5

    mouse_left_click = close_current
    mouse_middle_click = do_action
    mouse_right_click = close_all

[urgency_low]
    background = "#000000"
    foreground = "#9a9a9a"
    frame_color = "#2a2a2a"
    timeout = 4

[urgency_normal]
    background = "#000000"
    foreground = "#e6e6e6"
    frame_color = "#4a4a4a"
    timeout = 6

[urgency_critical]
    background = "#000000"
    foreground = "#ffffff"
    frame_color = "#ffffff"
    timeout = 0
