        },
        {
            "type": "sound",
            "key": "  ´Ç¿ audio",
            "keyColor": "magenta"
        },
        {
            "type": "player",
            "key": "  ¾░Ñá player",
            "keyColor": "magenta"
        },
        {
            "type": "media",
            "key": "  ¾░ØÜ media",
            "keyColor": "magenta"
        },
        {
            "type": "custom",
            "format": "{#4}Ôò░ÔöÇ {#15}\u001b[34mÔùÅ \u001b[36mÔùÅ \u001b[32mÔùÅ \u001b[33mÔùÅ \u001b[35mÔùÅ \u001b[31mÔùÅ\u001b[0m"
        },
        "break"
    ]
}
