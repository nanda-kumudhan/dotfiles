#!/bin/sh

direction=${1:-next}
visible_workspaces=$(
    swaymsg -t get_outputs |
        jq -c '[.[] | select(.active and .current_workspace != null) | .current_workspace]'
)

target=$(
    swaymsg -t get_tree |
        jq -r --arg direction "$direction" --argjson visible "$visible_workspaces" '
            [
                recurse(.nodes[]?, .floating_nodes[]?)
                | select(.type == "workspace" and (.name as $name | $visible | index($name)))
                | recurse(.nodes[]?, .floating_nodes[]?)
                | select(.type == "con" and (.app_id != null or .window_properties.class != null))
                | { id, focused }
            ] as $windows
            | ($windows | length) as $count
            | if $count == 0 then
                empty
              else
                (
                    [range(0; $count) | select($windows[.].focused)]
                    | first
                    // (if $direction == "prev" then 0 else -1 end)
                ) as $current
                | (
                    if $direction == "prev" then
                        ($current - 1 + $count) % $count
                    else
                        ($current + 1) % $count
                    end
                ) as $target
                | $windows[$target].id
              end
        '
)

[ -n "$target" ] && swaymsg "[con_id=$target] focus" >/dev/null
