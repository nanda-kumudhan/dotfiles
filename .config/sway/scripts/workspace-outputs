#!/bin/sh
set -eu

assign() {
    outputs=$(swaymsg -t get_outputs 2>/dev/null || printf '[]')
    current=$(swaymsg -t get_workspaces 2>/dev/null | jq -r '.[] | select(.focused).name' 2>/dev/null || printf '')
    external=$(printf '%s\n' "$outputs" | jq -r '
        [.[] | select(.active == true and (.name | startswith("eDP-") | not))]
        | first | .name // empty
    ')

    if [ -n "$external" ]; then
        for ws in 1 2 3 4 5 6 7 8 9; do
            swaymsg -q "workspace number $ws; move workspace to output $external"
        done
        [ "$current" ] && swaymsg -q "workspace $current"
        return 0
    fi

    for ws in 1 2 3 4 5 6 7 8 9; do
        swaymsg -q "workspace number $ws; move workspace to output eDP-1"
    done
    [ "$current" ] && swaymsg -q "workspace $current"
}

case "${1:-apply}" in
    apply)
        assign
        ;;
    *)
        printf 'usage: %s [apply]\n' "$0" >&2
        exit 2
        ;;
esac
