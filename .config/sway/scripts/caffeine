#!/bin/sh

runtime="${XDG_RUNTIME_DIR:-/tmp}"
state_file="$runtime/sway-caffeine.state"
lock="$HOME/.config/sway/scripts/lock"

is_on() {
    [ -f "$state_file" ]
}

start_idle() {
    pgrep -x swayidle >/dev/null 2>&1 && return 0

    swayidle -w \
        timeout 180 "$lock" \
        timeout 300 'swaymsg "output * power off"' \
        resume 'swaymsg "output * power on"' \
        before-sleep "$lock" &
}

status_json() {
    printf '{"text":"󰛉","class":"off","tooltip":"Use the Waybar idle inhibitor"}\n'
}

case "${1:-status}" in
    on)
        rm -f "$state_file"
        start_idle
        ;;
    off)
        rm -f "$state_file"
        start_idle
        ;;
    toggle)
        rm -f "$state_file"
        start_idle
        notify-send "Idle inhibitor" "Use the Waybar idle inhibitor button." 2>/dev/null || true
        ;;
    start)
        rm -f "$state_file"
        start_idle
        ;;
    status)
        status_json
        ;;
    *)
        printf 'usage: %s [on|off|toggle|start|status]\n' "$0" >&2
        exit 2
        ;;
esac
