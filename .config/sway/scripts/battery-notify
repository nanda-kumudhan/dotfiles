#!/bin/sh

BATTERY=${BATTERY_NOTIFY_BATTERY:-BAT0}
POWER_SUPPLY_DIR=${BATTERY_NOTIFY_POWER_DIR:-/sys/class/power_supply}
BATTERY_DIR="$POWER_SUPPLY_DIR/$BATTERY"
STATE_DIR=${BATTERY_NOTIFY_STATE_DIR:-${XDG_STATE_HOME:-$HOME/.local/state}}
STATE_FILE=${BATTERY_NOTIFY_STATE_FILE:-$STATE_DIR/battery-notify.state}

LOW_AT=${BATTERY_NOTIFY_LOW:-20}
CRITICAL_AT=${BATTERY_NOTIFY_CRITICAL:-10}
FULL_AT=${BATTERY_NOTIFY_FULL:-}

is_uint() {
    case "$1" in
        ''|*[!0-9]*) return 1 ;;
        *) return 0 ;;
    esac
}

read_value() {
    [ -r "$1" ] || return 1
    IFS= read -r value < "$1" || return 1
    printf '%s' "$value"
}

play_notice() {
    event=$1
    fallback=$2

    if command -v canberra-gtk-play >/dev/null 2>&1; then
        canberra-gtk-play -i "$event" -d "Battery notification" >/dev/null 2>&1 &
    elif command -v pw-play >/dev/null 2>&1 && [ -r "$fallback" ]; then
        pw-play "$fallback" >/dev/null 2>&1 &
    fi
}

send_notice() {
    urgency=$1
    title=$2
    message=$3
    event=$4
    fallback=$5

    if command -v notify-send >/dev/null 2>&1; then
        notify-send -a "Battery" -u "$urgency" "$title" "$message" >/dev/null 2>&1 || true
    fi
    play_notice "$event" "$fallback"
}

load_state() {
    LAST_ALERT=none

    if [ -r "$STATE_FILE" ]; then
        . "$STATE_FILE"
    fi

    case "$LAST_ALERT" in
        none|low|critical|full) ;;
        *) LAST_ALERT=none ;;
    esac
}

save_state() {
    state_dir=${STATE_FILE%/*}
    [ "$state_dir" = "$STATE_FILE" ] || mkdir -p "$state_dir" 2>/dev/null || return 0
    printf 'LAST_ALERT=%s\n' "$LAST_ALERT" > "$STATE_FILE" 2>/dev/null || true
}

is_uint "$LOW_AT" || LOW_AT=20
is_uint "$CRITICAL_AT" || CRITICAL_AT=10

if ! is_uint "$FULL_AT"; then
    FULL_AT=$(read_value "$BATTERY_DIR/charge_control_end_threshold") || FULL_AT=80
fi

[ -d "$BATTERY_DIR" ] || exit 0

capacity=$(read_value "$BATTERY_DIR/capacity") || exit 0
status=$(read_value "$BATTERY_DIR/status") || status=Unknown
is_uint "$capacity" || exit 0

load_state

case "$status" in
    Discharging)
        if [ "$capacity" -le "$CRITICAL_AT" ]; then
            if [ "$LAST_ALERT" != critical ]; then
                send_notice critical "Battery critical" "$capacity% remaining. Plug in soon." \
                    dialog-warning /usr/share/sounds/freedesktop/stereo/alarm-clock-elapsed.oga
                LAST_ALERT=critical
            fi
        elif [ "$capacity" -le "$LOW_AT" ]; then
            if [ "$LAST_ALERT" != low ]; then
                send_notice normal "Battery low" "$capacity% remaining." \
                    dialog-warning /usr/share/sounds/freedesktop/stereo/dialog-warning.oga
                LAST_ALERT=low
            fi
        else
            LAST_ALERT=none
        fi
        ;;
    Charging|Full|"Not charging")
        if [ "$capacity" -ge "$FULL_AT" ]; then
            if [ "$LAST_ALERT" != full ]; then
                send_notice normal "Charge limit reached" "$capacity% charged." \
                    complete /usr/share/sounds/freedesktop/stereo/complete.oga
                LAST_ALERT=full
            fi
        else
            LAST_ALERT=none
        fi
        ;;
    *)
        LAST_ALERT=none
        ;;
esac

save_state
