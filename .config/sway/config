
# --- Variables ---
set $mod Mod4

set $pass_manager keepassxc
set $term foot
set $file_manager Thunar
set $file_menu $HOME/.config/rofi/files
set $network_menu $HOME/.config/rofi/network
set $bluetooth_menu $HOME/.config/rofi/bluetooth
set $power_menu $HOME/.config/rofi/power
set $display_menu $HOME/.config/rofi/displays

# App launchers
set $launcher $HOME/.config/rofi/launcher
set $lock $HOME/.config/sway/scripts/lock
set $caffeine $HOME/.config/sway/scripts/caffeine
set $screenshot $HOME/.config/sway/scripts/screenshot
set $screenrecord $HOME/.config/sway/scripts/screenrecord
set $keybinds_help $HOME/.config/sway/scripts/keybinds-help
set $gui_env $HOME/.config/sway/scripts/gui-env
set $workspace_outputs $HOME/.config/sway/scripts/workspace-outputs
set $layout_titles $HOME/.config/sway/scripts/layout-titles
set $wallpaper $HOME/Pictures/wallpaper
set $session_env WAYLAND_DISPLAY XDG_CURRENT_DESKTOP XDG_SESSION_TYPE GTK_THEME GTK_ICON_THEME GDK_BACKEND QT_QPA_PLATFORM QT_QPA_PLATFORMTHEME QT_STYLE_OVERRIDE QT_WAYLAND_DISABLE_WINDOWDECORATION XCURSOR_THEME XCURSOR_SIZE
set $theme_assign XDG_CURRENT_DESKTOP=sway XDG_SESSION_TYPE=wayland GTK_THEME=Adwaita:dark GTK_ICON_THEME=Papirus-Dark GDK_BACKEND=wayland,x11 QT_QPA_PLATFORM='wayland;xcb' QT_QPA_PLATFORMTHEME=qt6ct QT_STYLE_OVERRIDE=Fusion QT_WAYLAND_DISABLE_WINDOWDECORATION=1 XCURSOR_THEME=Adwaita XCURSOR_SIZE=24

# --- Workspaces ---
set $ws1 "1"
set $ws2 "2"
set $ws3 "3"
set $ws4 "4"
set $ws5 "5"
set $ws6 "6"
set $ws7 "7"
set $ws8 "8"
set $ws9 "9"

# --- Theme ---
set $m_bg #000000
set $m_active #4a4a4a
set $m_inactive #2a2a2a
set $m_urgent #ffffff
set $m_text #e6e6e6

font pango:JetBrainsMono Nerd Font 10
default_border normal 2
default_floating_border normal 2
titlebar_border_thickness 1
titlebar_padding 6 3
title_align center
show_marks no
gaps inner 3
gaps outer 2
smart_gaps off
smart_borders on
hide_edge_borders smart

# Apply theme geometry to already-open windows and workspaces on reload.
exec_always swaymsg -q '[all] border normal 2'
exec_always swaymsg -q gaps inner all set 3
exec_always swaymsg -q gaps outer all set 2

client.focused $m_active $m_bg $m_text $m_active $m_active
client.focused_inactive $m_inactive $m_bg #9a9a9a $m_inactive $m_inactive
client.focused_tab_title $m_active $m_bg $m_text
client.unfocused $m_bg $m_bg #666666 $m_inactive $m_inactive
client.urgent $m_urgent $m_bg $m_urgent $m_urgent $m_urgent

# --- Startup ---

# Removable media
exec udiskie --no-tray --notify

# --- Session Services ---
exec $gui_env $HOME/.local/bin/start-polkit-agent

# Export the Wayland session to DBus/systemd.
exec dbus-update-activation-environment --systemd WAYLAND_DISPLAY $theme_assign
exec systemctl --user import-environment WAYLAND_DISPLAY
exec systemctl --user set-environment $theme_assign
exec systemctl --user start sway-session.target

# Keep a stable SSH_AUTH_SOCK for KeePassXC.
exec sh -c 'export SSH_AUTH_SOCK="$XDG_RUNTIME_DIR/ssh-agent.socket"; test -S "$SSH_AUTH_SOCK" || ssh-agent -a "$SSH_AUTH_SOCK"; dbus-update-activation-environment --systemd SSH_AUTH_SOCK; systemctl --user import-environment SSH_AUTH_SOCK'

# KeePassXC integration
exec $gui_env env SSH_AUTH_SOCK="$XDG_RUNTIME_DIR/ssh-agent.socket" QT_QPA_PLATFORMTHEME=qt5ct QT_STYLE_OVERRIDE=Fusion keepassxc

# Notifications
exec_always sh -c 'command -v mako >/dev/null || exit 0; pkill -x mako 2>/dev/null; mako'

# Automatic split direction
exec_always sh -c 'command -v autotiling >/dev/null 2>&1 || exit 0; pkill -x autotiling 2>/dev/null; exec autotiling'

# Show each window's parent layout in its title bar.
exec_always sh -c 'pkill -f "[l]ayout-titles watch" 2>/dev/null || true; exec "$HOME/.config/sway/scripts/layout-titles" watch'

# Wallpaper
output * bg $wallpaper fill

# Output profiles; no-op until kanshi is installed.
exec_always sh -c 'command -v kanshi >/dev/null 2>&1 || exit 0; pkill -x kanshi 2>/dev/null; exec kanshi'

# --- Input ---
seat * xcursor_theme Adwaita 24
input * xkb_layout gb

input "type:touchpad" {
    tap disabled
    natural_scroll enabled
    dwt enabled
    middle_emulation enabled
}

input "type:pointer" {
	natural_scroll enabled
}

focus_follows_mouse no

# --- Idle & Power ---
# Lock and power management
exec_always $caffeine start

# --- Keybinds ---

# Launchers

bindsym Ctrl+Mod1+t exec $term
bindsym $mod+e exec $file_menu
bindsym $mod+Shift+e exec $gui_env $file_manager
bindsym $mod+space exec $launcher
bindsym $mod+q kill
bindsym $mod+l exec $lock
bindsym $mod+Shift+l exec $caffeine toggle
bindsym Ctrl+Escape exec $term -T "sysmon" -e htop
bindsym Print exec $screenshot full
bindsym Shift+Print exec $screenshot region
bindsym Ctrl+Print exec $screenrecord full
bindsym Ctrl+Shift+Print exec $screenrecord region
bindsym $mod+slash exec $keybinds_help

# Window management
bindsym $mod+h splith, exec $layout_titles refresh
bindsym $mod+v splitv, exec $layout_titles refresh
bindsym $mod+r layout toggle split, exec $layout_titles refresh
bindsym $mod+f fullscreen toggle
bindsym $mod+d floating toggle
bindsym $mod+Shift+d sticky toggle
bindsym $mod+p exec $display_menu
bindsym $mod+Shift+p exec $gui_env wdisplays
bindsym $mod+c move position center
bindsym $mod+t layout tabbed, exec $layout_titles refresh
bindsym $mod+Shift+r reload
bindsym $mod+s layout stacking, exec $layout_titles refresh

bindsym $mod+plus resize grow width 40 px
bindsym $mod+minus resize shrink width 40 px

bindsym $mod+Left focus left
bindsym $mod+Down focus down
bindsym $mod+Up focus up
bindsym $mod+Right focus right
bindsym $mod+a focus parent
bindsym $mod+Shift+a focus child

bindsym $mod+Shift+Left move left
bindsym $mod+Shift+Down move down
bindsym $mod+Shift+Up move up
bindsym $mod+Shift+Right move right

# Workspaces
bindsym $mod+1 workspace number $ws1, exec $workspace_outputs
bindsym $mod+2 workspace number $ws2, exec $workspace_outputs
bindsym $mod+3 workspace number $ws3, exec $workspace_outputs
bindsym $mod+4 workspace number $ws4, exec $workspace_outputs
bindsym $mod+5 workspace number $ws5, exec $workspace_outputs
bindsym $mod+6 workspace number $ws6, exec $workspace_outputs
bindsym $mod+7 workspace number $ws7, exec $workspace_outputs
bindsym $mod+8 workspace number $ws8, exec $workspace_outputs
bindsym $mod+9 workspace number $ws9, exec $workspace_outputs

bindsym $mod+Shift+1 move container to workspace number $ws1, exec $workspace_outputs
bindsym $mod+Shift+2 move container to workspace number $ws2, exec $workspace_outputs
bindsym $mod+Shift+3 move container to workspace number $ws3, exec $workspace_outputs
bindsym $mod+Shift+4 move container to workspace number $ws4, exec $workspace_outputs
bindsym $mod+Shift+5 move container to workspace number $ws5, exec $workspace_outputs
bindsym $mod+Shift+6 move container to workspace number $ws6, exec $workspace_outputs
bindsym $mod+Shift+7 move container to workspace number $ws7, exec $workspace_outputs
bindsym $mod+Shift+8 move container to workspace number $ws8, exec $workspace_outputs
bindsym $mod+Shift+9 move container to workspace number $ws9, exec $workspace_outputs

bindsym $mod+Ctrl+Right move workspace to output right
bindsym $mod+Ctrl+Left move workspace to output left

bindsym $mod+Tab workspace next
bindsym $mod+Shift+Tab workspace prev
bindsym Mod1+Tab exec $HOME/.config/sway/scripts/cycle-app next
bindsym Mod1+Shift+Tab exec $HOME/.config/sway/scripts/cycle-app prev

# Session actions
bindsym $mod+Shift+s exec systemctl suspend

# App shortcuts
bindsym $mod+b exec $bluetooth_menu
bindsym $mod+k exec $gui_env env QT_QPA_PLATFORMTHEME=qt5ct QT_STYLE_OVERRIDE=Fusion keepassxc --minimized
bindsym $mod+n exec $network_menu
bindsym $mod+w exec $gui_env librewolf
bindsym $mod+x exec $gui_env vscodium
bindsym $mod+z exec $term -T "neovim" -e nvim

# Scratchpad: hide/show any focused window
bindsym $mod+Shift+grave move scratchpad
bindsym $mod+grave scratchpad show

# --- Function Keys ---

# Audio
bindsym XF86AudioMute exec wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle
bindsym $mod+XF86AudioMicMute exec $HOME/.config/rofi/pipewire-input
bindsym $mod+XF86AudioMute exec $HOME/.config/rofi/pipewire-output
bindsym XF86AudioLowerVolume exec wpctl set-volume @DEFAULT_AUDIO_SINK@ 1%-
bindsym XF86AudioRaiseVolume exec "wpctl set-volume -l 1.0 @DEFAULT_AUDIO_SINK@ 1%+"
bindsym XF86AudioMicMute exec wpctl set-mute @DEFAULT_AUDIO_SOURCE@ toggle

# System / media
bindsym XF86Tools exec $gui_env pavucontrol
bindsym XF86Display exec $display_menu
bindsym XF86AudioPrev exec playerctl previous
bindsym XF86AudioNext exec playerctl next
bindsym XF86AudioPlay exec playerctl play-pause
bindsym XF86MonBrightnessDown exec "brightnessctl s 3%- -n 0.3l%"
bindsym XF86MonBrightnessUp exec "brightnessctl set +3%"
bindsym XF86AudioStop exec playerctl stop

# Power / lid
bindsym Ctrl+Alt+Delete exec $power_menu
bindswitch --reload --locked lid:on output eDP-1 disable
bindswitch --reload --locked lid:off output eDP-1 enable

# --- Window Rules ---

# Keep fullscreen apps from idling the session
for_window [class="mpv"] inhibit_idle fullscreen
for_window [app_id="librewolf"] inhibit_idle fullscreen
for_window [class="LibreWolf"] inhibit_idle fullscreen

# Floating dialogs and utilities
for_window [app_id="org.keepassxc.KeePassXC"] floating enable, move position center
for_window [class="KeePassXC"] floating enable, move position center
for_window [app_id="Thunar"] floating enable, move position center
for_window [app_id="gnome-disks"] floating enable, move position center
for_window [app_id="wdisplays"] floating enable, move position center
for_window [app_id="org.gnome.DiskUtility"] floating enable, move position center
for_window [app_id="mpv"] floating enable, move position center
for_window [app_id="foot" title="sysmon"] floating enable, move position center
for_window [app_id="scratchpad_term"] floating enable, resize set 80% 70%, move position center
for_window [app_id="nm_panel"] floating enable, resize set 600 400, move position center
for_window [app_id="network-vpn"] floating enable, resize set 760 520, move position center
for_window [class="pavucontrol"] floating enable, resize set 640 420, move position center
for_window [app_id="pavucontrol"] floating enable, resize set 640 420, move position center

# Output positions are managed by kanshi.

bar {
    position top
    swaybar_command waybar
}
