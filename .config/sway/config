set $term foot
set $file_manager Thunar
set $file_menu exec rofi -show filebrowser
set $power_menu swaynag -t warning -m "Do you want to exit Sway?" \
  -B "Logout" "swaymsg exit"
set $editor zed

exec dunst
exec kanshi
exec autotiling

exec --no-startup-id gnome-keyring-daemon --start --components=pkcs11,secrets,ssh
exec_always dbus-update-activation-environment --systemd WAYLAND_DISPLAY SWAYSOCK XDG_CURRENT_DESKTOP XDG_SESSION_DESKTOP PATH
exec systemctl --user import-environment SWAYSOCK WAYLAND_DISPLAY XDG_CURRENT_DESKTOP XDG_SESSION_DESKTOP

# App launchers
set $launcher exec rofi -show drun -show-icons -icon-theme "Papirus" -drun-display-format "{name}" -p "Apps"

# --- Workspaces ---
set $ws1 "1"
set $ws2 "2"
set $ws3 "3"
set $ws4 "4"
set $ws5 "5"
set $ws6 "6"
set $ws7 "7"
set $ws8 "8"
set $ws9 "9"
xwayland enable
# --- Theme ---
set $m_bg #000000
set $m_active #4a4a4a
set $m_inactive #2a2a2a
set $m_urgent #ffffff
set $m_text #e6e6e6

font pango:JetBrainsMono Nerd Font 10
default_border normal 2
default_floating_border normal 2
titlebar_border_thickness 1
titlebar_padding 6 3
title_align center
show_marks no
gaps inner 3
gaps outer 2
smart_gaps off
smart_borders on
hide_edge_borders smart

# Apply theme geometry to already-open windows and workspaces on reload.
exec_always swaymsg -q '[all] border normal 2'
exec_always swaymsg -q gaps inner all set 3
exec_always swaymsg -q gaps outer all set 2

exec udiskie --smart-tray --automount

client.focused $m_active $m_bg $m_text $m_active $m_active
client.focused_inactive $m_inactive $m_bg #9a9a9a $m_inactive $m_inactive
client.focused_tab_title $m_active $m_bg $m_text
client.unfocused $m_bg $m_bg #666666 $m_inactive $m_inactive
client.urgent $m_urgent $m_bg $m_urgent $m_urgent $m_urgent

# --- Startup ---

# --- Session Services ---
exec $HOME/.local/bin/start-polkit-agent

# Export the Wayland session to DBus/systemd.
exec dbus-update-activation-environment --systemd WAYLAND_DISPLAY DISPLAY SWAYSOCK XDG_CURRENT_DESKTOP
exec systemctl --user import-environment WAYLAND_DISPLAY DISPLAY SWAYSOCK XDG_CURRENT_DESKTOP
exec systemctl --user start sway-session.target

# Wallpaper
exec swaybg -i '/home/nanda-kumudhan/Pictures/wallpaper'

# --- Input ---
seat * xcursor_theme Adwaita 24
input * xkb_layout gb

input "type:touchpad" {
    tap disabled
    natural_scroll enabled
    dwt enabled
    middle_emulation enabled
}

input "type:pointer" {
	natural_scroll enabled
}

focus_follows_mouse no

exec nm-applet --indicator
exec blueman-applet

# --- Idle & Power ---
# Lock and power management
exec swayidle -w \
    timeout 300 'swaylock -f' \
    timeout 600 'systemctl suspend' \
    before-sleep 'swaylock -f' \
    after-resume 'swaymsg "output * power on"'

# --- Keybinds ---

# Launchers

bindsym Ctrl+Mod1+t exec $term
bindsym Mod4+e exec $file_menu
bindsym Mod4+Shift+e exec $file_manager
bindsym Mod4+space exec $launcher
bindsym Mod4+q kill
bindsym Mod4+l exec swaylock
bindsym Ctrl+Escape exec $term -T "sysmon" -e htop

# Full screenshot
bindsym Print exec grim ~/Pictures/Screenshots/$(date +'%Y-%m-%d_%H-%M-%S').png

# Region screenshot
bindsym Shift+Print exec grim -g "$(slurp)" ~/Pictures/Screenshots/$(date +'%Y-%m-%d_%H-%M-%S').png
# Window management
bindsym Mod4+h splith, exec $layout_titles refresh
bindsym Mod4+v splitv, exec $layout_titles refresh
bindsym Mod4+r layout toggle split, exec $layout_titles refresh
bindsym Mod4+f fullscreen toggle
bindsym Mod4+d floating toggle
bindsym Mod4+Shift+d sticky toggle
bindsym Mod4+Shift+p exec wdisplays
bindsym Mod4+c move position center
bindsym Mod4+t layout tabbed, exec $layout_titles refresh
bindsym Mod4+Shift+r reload
bindsym Mod4+s layout stacking, exec $layout_titles refresh

bindsym Mod4+plus resize grow width 40 px
bindsym Mod4+minus resize shrink width 40 px

bindsym Mod4+Left focus left
bindsym Mod4+Down focus down
bindsym Mod4+Up focus up
bindsym Mod4+Right focus right
bindsym Mod4+a focus parent
bindsym Mod4+Shift+a focus child

bindsym Mod4+Shift+Left move left
bindsym Mod4+Shift+Down move down
bindsym Mod4+Shift+Up move up
bindsym Mod4+Shift+Right move right

# Workspaces
bindsym Mod4+1 workspace number $ws1
bindsym Mod4+2 workspace number $ws2
bindsym Mod4+3 workspace number $ws3
bindsym Mod4+4 workspace number $ws4
bindsym Mod4+5 workspace number $ws5
bindsym Mod4+6 workspace number $ws6
bindsym Mod4+7 workspace number $ws7
bindsym Mod4+8 workspace number $ws8
bindsym Mod4+9 workspace number $ws9

bindsym Mod4+Shift+1 move container to workspace number $ws1
bindsym Mod4+Shift+2 move container to workspace number $ws2
bindsym Mod4+Shift+3 move container to workspace number $ws3
bindsym Mod4+Shift+4 move container to workspace number $ws4
bindsym Mod4+Shift+5 move container to workspace number $ws5
bindsym Mod4+Shift+6 move container to workspace number $ws6
bindsym Mod4+Shift+7 move container to workspace number $ws7
bindsym Mod4+Shift+8 move container to workspace number $ws8
bindsym Mod4+Shift+9 move container to workspace number $ws9

bindsym Mod4+Ctrl+Right move workspace to output right
bindsym Mod4+Ctrl+Left move workspace to output left

bindsym Mod4+Tab workspace next
bindsym Mod4+Shift+Tab workspace prev
bindsym Mod1+Tab focus next
bindsym Mod1+Shift+Tab focus prev

# Session actions
bindsym Mod4+Shift+s exec systemctl suspend

# App shortcuts
bindsym Mod4+b exec blueman-manager
bindsym Mod4+k exec keepassxc --minimized
bindsym Mod4+z exec $editor

# Scratchpad: hide/show any focused window
bindsym Mod4+Shift+grave move scratchpad
bindsym Mod4+grave scratchpad show

# --- Function Keys ---

# Audio
bindsym XF86AudioMute exec wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle
bindsym XF86AudioLowerVolume exec wpctl set-volume @DEFAULT_AUDIO_SINK@ 1%-
bindsym XF86AudioRaiseVolume exec "wpctl set-volume -l 1.0 @DEFAULT_AUDIO_SINK@ 1%+"
bindsym XF86AudioMicMute exec wpctl set-mute @DEFAULT_AUDIO_SOURCE@ toggle

# System / media
bindsym XF86Tools exec pavucontrol
bindsym XF86Display exec $display_menu
bindsym XF86AudioPrev exec playerctl previous
bindsym XF86AudioNext exec playerctl next
bindsym XF86AudioPlay exec playerctl play-pause
bindsym XF86MonBrightnessDown exec "brightnessctl s 3%- -n 0.3l%"
bindsym XF86MonBrightnessUp exec "brightnessctl set +3%"
bindsym XF86AudioStop exec playerctl stop

# Power / lid
bindsym Ctrl+Alt+Delete exec $power_menu
bindswitch --reload --locked lid:on output eDP-1 disable
bindswitch --reload --locked lid:off output eDP-1 enable

# --- Window Rules ---

# Floating dialogs and utilities
for_window [app_id="keepassxc"] floating enable, move position center
for_window [app_id="Thunar"] floating enable, move position center
for_window [app_id="gnome-disks"] floating enable, move position center
for_window [app_id="wdisplays"] floating enable, move position center
for_window [app_id="org.gnome.DiskUtility"] floating enable, move position center
for_window [app_id="mpv"] floating enable, move position center
for_window [app_id="foot" title="sysmon"] floating enable, move position center
for_window [app_id="scratchpad_term"] floating enable, resize set 80% 70%, move position center
for_window [class="pavucontrol"] floating enable, resize set 640 420, move position center
for_window [app_id="pavucontrol"] floating enable, resize set 640 420, move position center
for_window [class="blueman-manager"] floating enable, resize set 640 420, move position center
for_window [app_id="blueman-manager"] floating enable, resize set 640 420, move position center


bar {
    position top
    swaybar_command waybar
}
