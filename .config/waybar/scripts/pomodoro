#!/bin/sh

is_uint() {
    case "$1" in
        ''|*[!0-9]*) return 1 ;;
        *) return 0 ;;
    esac
}

number_or_default() {
    if is_uint "$1"; then
        printf '%s' "$1"
    else
        printf '%s' "$2"
    fi
}

WORK_MIN=$(number_or_default "${POMODORO_WORK_MIN:-}" 25)
SHORT_MIN=$(number_or_default "${POMODORO_SHORT_MIN:-}" 5)
LONG_MIN=$(number_or_default "${POMODORO_LONG_MIN:-}" 15)
LONG_EVERY=$(number_or_default "${POMODORO_LONG_EVERY:-}" 4)

[ "$LONG_EVERY" -gt 0 ] || LONG_EVERY=4

WORK_SECONDS=$((WORK_MIN * 60))
SHORT_SECONDS=$((SHORT_MIN * 60))
LONG_SECONDS=$((LONG_MIN * 60))

RUNTIME=${XDG_RUNTIME_DIR:-/tmp}
STATE_FILE="$RUNTIME/waybar-pomodoro.state"
DAEMON_PID_FILE="$RUNTIME/waybar-pomodoro.pid"
WAYBAR_SIGNAL=8
DEFAULT_SOUND=/usr/share/sounds/freedesktop/stereo/complete.oga
POMODORO_SOUND=${POMODORO_SOUND:-$DEFAULT_SOUND}

notify() {
    command -v notify-send >/dev/null 2>&1 && notify-send "Pomodoro" "$1" >/dev/null 2>&1
}

play_sound() {
    [ -n "$POMODORO_SOUND" ] || return
    [ -r "$POMODORO_SOUND" ] || return

    if command -v pw-play >/dev/null 2>&1; then
        pw-play "$POMODORO_SOUND" >/dev/null 2>&1 &
    elif command -v paplay >/dev/null 2>&1; then
        paplay "$POMODORO_SOUND" >/dev/null 2>&1 &
    elif command -v canberra-gtk-play >/dev/null 2>&1; then
        canberra-gtk-play -f "$POMODORO_SOUND" >/dev/null 2>&1 &
    fi
}

alert() {
    notify "$1"
    play_sound
}

refresh_waybar() {
    signal=$(kill -l "RTMIN+$WAYBAR_SIGNAL" 2>/dev/null || true)
    if is_uint "$signal"; then
        pkill -"$signal" -x waybar 2>/dev/null || true
    fi
}

daemon_pid() {
    [ -r "$DAEMON_PID_FILE" ] || return 1
    pid=$(cat "$DAEMON_PID_FILE" 2>/dev/null || true)
    is_uint "$pid" || return 1
    printf '%s' "$pid"
}

daemon_running() {
    pid=$(daemon_pid) || return 1
    kill -0 "$pid" 2>/dev/null
}

stop_daemon() {
    pid=$(daemon_pid) || {
        rm -f "$DAEMON_PID_FILE"
        return
    }

    kill "$pid" 2>/dev/null || true
    rm -f "$DAEMON_PID_FILE"
}

ensure_daemon() {
    [ "$STATUS" = "running" ] || return
    daemon_running && return

    "$0" daemon >/dev/null 2>&1 &
}

now() {
    date +%s
}

load_state() {
    PHASE=idle
    STATUS=stopped
    END_AT=0
    REMAINING=$WORK_SECONDS
    COMPLETED=0

    if [ -r "$STATE_FILE" ]; then
        . "$STATE_FILE"
    fi

    case "$PHASE" in
        idle|work|short|long) ;;
        *) PHASE=idle ;;
    esac

    case "$STATUS" in
        stopped|running|paused) ;;
        *) STATUS=stopped ;;
    esac

    is_uint "$END_AT" || END_AT=0
    is_uint "$REMAINING" || REMAINING=$WORK_SECONDS
    is_uint "$COMPLETED" || COMPLETED=0
}

save_state() {
    {
        printf 'PHASE=%s\n' "$PHASE"
        printf 'STATUS=%s\n' "$STATUS"
        printf 'END_AT=%s\n' "$END_AT"
        printf 'REMAINING=%s\n' "$REMAINING"
        printf 'COMPLETED=%s\n' "$COMPLETED"
    } > "$STATE_FILE"
}

phase_seconds() {
    case "$1" in
        work) printf '%s' "$WORK_SECONDS" ;;
        short) printf '%s' "$SHORT_SECONDS" ;;
        long) printf '%s' "$LONG_SECONDS" ;;
        *) printf '%s' "$WORK_SECONDS" ;;
    esac
}

phase_label() {
    case "$1" in
        work) printf 'Work' ;;
        short) printf 'Short break' ;;
        long) printf 'Long break' ;;
        *) printf 'Idle' ;;
    esac
}

start_phase() {
    PHASE=$1
    STATUS=running
    REMAINING=$(phase_seconds "$PHASE")
    END_AT=$(($(now) + REMAINING))
    save_state
}

finish_phase() {
    case "$PHASE" in
        work)
            COMPLETED=$((COMPLETED + 1))
            if [ $((COMPLETED % LONG_EVERY)) -eq 0 ]; then
                start_phase long
                alert "Work done. Long break started."
            else
                start_phase short
                alert "Work done. Short break started."
            fi
            ;;
        short|long)
            start_phase work
            alert "Break done. Work started."
            ;;
        *)
            start_phase work
            notify "Work started."
            ;;
    esac
}

tick() {
    [ "$STATUS" = "running" ] || return

    current=$(now)
    if [ "$END_AT" -le "$current" ]; then
        finish_phase
    else
        REMAINING=$((END_AT - current))
    fi
}

toggle() {
    load_state

    case "$STATUS" in
        running)
            current=$(now)
            REMAINING=$((END_AT - current))
            [ "$REMAINING" -gt 0 ] || REMAINING=0
            STATUS=paused
            END_AT=0
            save_state
            stop_daemon
            ;;
        paused)
            [ "$REMAINING" -gt 0 ] || REMAINING=$(phase_seconds "$PHASE")
            STATUS=running
            END_AT=$(($(now) + REMAINING))
            save_state
            ensure_daemon
            ;;
        *)
            COMPLETED=0
            start_phase work
            notify "Work started."
            ensure_daemon
            ;;
    esac

    refresh_waybar
}

reset_timer() {
    stop_daemon
    PHASE=idle
    STATUS=stopped
    END_AT=0
    REMAINING=$WORK_SECONDS
    COMPLETED=0
    save_state
    notify "Timer reset."
    refresh_waybar
}

skip_phase() {
    load_state
    finish_phase
    ensure_daemon
    refresh_waybar
}

next_update_delay() {
    remaining=$REMAINING

    [ "$remaining" -gt 0 ] || {
        printf '1'
        return
    }

    delay=$((remaining % 60))
    [ "$delay" -gt 0 ] || delay=60
    [ "$delay" -le "$remaining" ] || delay=$remaining

    printf '%s' "$delay"
}

daemon() {
    printf '%s\n' "$$" > "$DAEMON_PID_FILE"
    trap 'rm -f "$DAEMON_PID_FILE"; exit 0' INT TERM EXIT

    while :; do
        load_state
        tick

        if [ "$STATUS" != "running" ]; then
            refresh_waybar
            exit 0
        fi

        refresh_waybar
        sleep "$(next_update_delay)" || exit 0
    done
}

format_minutes() {
    seconds=$1
    [ "$seconds" -gt 0 ] || seconds=0
    printf '%sm' $(((seconds + 59) / 60))
}

format_remaining() {
    seconds=$1
    [ "$seconds" -gt 0 ] || seconds=0
    mins=$(((seconds + 59) / 60))

    [ "$mins" -eq 1 ] && printf '1 min' || printf '%s min' "$mins"
}

render() {
    load_state
    tick
    ensure_daemon

    case "$STATUS" in
        stopped)
            text='󰔟'
            class='idle'
            tooltip='Pomodoro idle\nLeft: start\nRight: reset\nMiddle: skip'
            ;;
        paused)
            text="󰔟 $(format_minutes "$REMAINING")"
            class='paused'
            tooltip="Pomodoro paused\nPhase: $(phase_label "$PHASE")\nRemaining: $(format_remaining "$REMAINING")\nCompleted: $COMPLETED"
            ;;
        running)
            case "$PHASE" in
                short|long)
                    text="󰔛 $(format_minutes "$REMAINING")"
                    class='break'
                    ;;
                *)
                    text="󰔟 $(format_minutes "$REMAINING")"
                    class='work'
                    ;;
            esac
            tooltip="Pomodoro running\nPhase: $(phase_label "$PHASE")\nRemaining: $(format_remaining "$REMAINING")\nCompleted: $COMPLETED"
            ;;
    esac

    printf '{"text":"%s","tooltip":"%s","class":"%s"}\n' "$text" "$tooltip" "$class"
}

case "${1:-render}" in
    toggle) toggle ;;
    reset) reset_timer ;;
    skip) skip_phase ;;
    daemon) daemon ;;
    render) render ;;
    *) render ;;
esac
