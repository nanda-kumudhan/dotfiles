#!/usr/bin/env bash

set -u

ROFI_CMD="${ROFI_CMD:-rofi -dmenu -i}"

notify() {
    command -v notify-send >/dev/null 2>&1 &&
        notify-send "Displays" "$1"
}

need_cmd() {
    command -v "$1" >/dev/null 2>&1 || {
        notify "Missing dependency: $1"
        exit 1
    }
}

outputs_json() {
    swaymsg -t get_outputs -r 2>/dev/null
}

output_label() {
    local output="$1"

    jq -r --arg output "$output" '
        .[] | select(.name == $output)
        | [.make, .model] | map(select(. != null and . != "")) | join(" ")
    ' <<<"$outputs"
}

choose_external() {
    local selected

    if [ "${#externals[@]}" -eq 1 ]; then
        printf '%s\n' "${externals[0]}"
        return
    fi

    selected="$(
        for output in "${externals[@]}"; do
            printf '%s\t%s    %s\n' "$output" "$output" "$(output_label "$output")"
        done | eval "$ROFI_CMD" -p "External display" -display-column 2
    )"

    printf '%s\n' "$selected" | cut -f1
}

rect_value() {
    local output="$1"
    local field="$2"

    jq -r --arg output "$output" --arg field "$field" '
        .[] | select(.name == $output)
        | if $field == "width" then
            if .rect.width > 0 then .rect.width
            else (((.current_mode.width // .modes[0].width // 0) / (.scale // 1)) | floor)
            end
          elif $field == "height" then
            if .rect.height > 0 then .rect.height
            else (((.current_mode.height // .modes[0].height // 0) / (.scale // 1)) | floor)
            end
          else
            .rect[$field]
          end
    ' <<<"$outputs"
}

place() {
    local relation="$1"
    local laptop_width laptop_height external_width external_height
    local laptop_x laptop_y external_x external_y

    laptop_width="$(rect_value "$laptop" width)"
    laptop_height="$(rect_value "$laptop" height)"
    external_width="$(rect_value "$external" width)"
    external_height="$(rect_value "$external" height)"

    case "$relation" in
        left)
            external_x=0 external_y=0
            laptop_x=$external_width laptop_y=0
            ;;
        right)
            laptop_x=0 laptop_y=0
            external_x=$laptop_width external_y=0
            ;;
        above)
            external_x=0 external_y=0
            laptop_x=0 laptop_y=$external_height
            ;;
        below)
            laptop_x=0 laptop_y=0
            external_x=0 external_y=$laptop_height
            ;;
        mirror)
            laptop_x=0 laptop_y=0
            external_x=0 external_y=0
            ;;
    esac

    swaymsg -q "output $laptop enable position $laptop_x $laptop_y"
    swaymsg -q "output $external enable position $external_x $external_y"
}

swap_outputs() {
    local laptop_x laptop_y external_x external_y

    laptop_x="$(rect_value "$laptop" x)"
    laptop_y="$(rect_value "$laptop" y)"
    external_x="$(rect_value "$external" x)"
    external_y="$(rect_value "$external" y)"

    swaymsg -q "output $laptop position $external_x $external_y"
    swaymsg -q "output $external position $laptop_x $laptop_y"
}

main() {
    need_cmd swaymsg
    need_cmd jq
    need_cmd rofi

    outputs="$(outputs_json)" || {
        notify "Cannot connect to Sway."
        exit 1
    }

    laptop="$(
        jq -r '[.[] | select(.name | startswith("eDP-"))] | first | .name // empty' \
            <<<"$outputs"
    )"
    if [ -z "$laptop" ]; then
        laptop="$(
            jq -r '[.[] | select(.active and (.non_desktop | not))] | first | .name // empty' \
                <<<"$outputs"
        )"
    fi

    mapfile -t externals < <(
        jq -r --arg laptop "$laptop" \
            '.[] | select(.name != $laptop and (.non_desktop | not)) | .name' <<<"$outputs"
    )

    if [ -z "$laptop" ]; then
        notify "No active display found."
        exit 1
    fi

    if [ "${#externals[@]}" -eq 0 ]; then
        notify "No external display found."
        exit 0
    fi

    external="$(choose_external)"
    [ -n "$external" ] || exit 0

    choice="$(
        printf '%s\n' \
            "External left of laptop" \
            "External right of laptop" \
            "External above laptop" \
            "External below laptop" \
            "Mirror laptop and external" \
            "Swap current positions" \
            "External only" \
            "Laptop only" |
            eval "$ROFI_CMD" -p "Display layout"
    )"

    case "$choice" in
        "External left of laptop") place left ;;
        "External right of laptop") place right ;;
        "External above laptop") place above ;;
        "External below laptop") place below ;;
        "Mirror laptop and external") place mirror ;;
        "Swap current positions") swap_outputs ;;
        "External only")
            swaymsg -q "output $external enable position 0 0"
            swaymsg -q "output $laptop disable"
            ;;
        "Laptop only")
            swaymsg -q "output $laptop enable position 0 0"
            for output in "${externals[@]}"; do
                swaymsg -q "output $output disable"
            done
            ;;
        *) exit 0 ;;
    esac

    notify "Applied: $choice"
}

main "$@"
