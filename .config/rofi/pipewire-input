#!/usr/bin/env bash

set -euo pipefail

choice="$(
  wpctl status | awk '
    /Sources:/ { in_sources=1; next }
    /Filters:/ { in_sources=0 }
    in_sources && /^[[:space:]│├─*]*[0-9]+\./ {
      line=$0
      gsub(/^[[:space:]│├─*]*/, "", line)
      print line
    }
  ' | rofi -dmenu -i -p "Input"
)"

[[ -z "${choice:-}" ]] && exit 0

id="$(awk '{print $1}' <<< "$choice" | tr -d '.')"

wpctl set-default "$id"

command -v notify-send >/dev/null 2>&1 && \
  notify-send "PipeWire" "Input set to: $choice"