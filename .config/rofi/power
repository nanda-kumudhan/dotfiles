#!/bin/sh

ROFI=${ROFI:-rofi}
TAB=$(printf '\t')
LOCK="$HOME/.config/sway/scripts/lock"

CONFIRM_THEME='
window { width: 24%; }
listview { lines: 2; }
entry { placeholder: ""; }
element { padding: 10px 12px; }
'

menu() {
    "$ROFI" \
        -dmenu \
        -i \
        -matching fuzzy \
        -sync \
        -p "Power" \
        -show-icons \
        -icon-theme "Papirus" \
        -selected-row 0 \
        -theme "$HOME/.config/rofi/power-grid.rasi"
}

confirm() {
    action=$1

    choice=$(
        {
            printf '%s\t%s\n' "No" "cancel"
            printf '%s\t%s\n' "Yes, $action" "yes"
        } | "$ROFI" \
            -dmenu \
            -i \
            -sync \
            -p "$action?" \
            -mesg "Confirm action" \
            -display-columns 1 \
            -display-column-separator "$TAB" \
            -selected-row 0 \
            -theme-str "$CONFIRM_THEME"
    )

    [ "$(printf '%s' "$choice" | cut -f2)" = "yes" ]
}

require rofi

choice=$(
    {
        printf '󰌾 Lock\n'
        printf '󰤄 Sleep\n'
        printf '󰍃 Log out\n'
        printf '󰜉 Reboot\n'
        printf '󰐥 Shutdown\n'
    } | menu
)

case "$choice" in
    *Lock)
        exec "$LOCK"
        ;;
    *Sleep)
        systemctl suspend
        ;;
    *"Log out")
        confirm "Log out" && swaymsg exit
        ;;
    *Reboot)
        confirm "Reboot" && systemctl reboot
        ;;
    *Shutdown)
        confirm "Shutdown" && systemctl poweroff
        ;;
esac