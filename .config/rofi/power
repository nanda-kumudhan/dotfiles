#!/bin/sh

ROFI=${ROFI:-rofi}
TAB=$(printf '\t')
LOCK="$HOME/.config/sway/scripts/lock"

CONFIRM_THEME='
window { width: 24%; }
listview { lines: 2; }
entry { placeholder: ""; }
element { padding: 10px 12px; }
'

notify() {
    command -v notify-send >/dev/null 2>&1 && notify-send "$@"
}

require() {
    if ! command -v "$1" >/dev/null 2>&1; then
        notify "Power menu" "$1 is not installed"
        exit 1
    fi
}

menu() {
    "$ROFI" \
        -dmenu \
        -i \
        -matching fuzzy \
        -sync \
        -p "Power" \
        -show-icons \
        -icon-theme "rofi-power-nerd" \
        -selected-row 0 \
        -theme "$HOME/.config/rofi/power-grid.rasi"
}

confirm() {
    action=$1

    choice=$(
        {
            printf '%s\t%s\n' "No" "cancel"
            printf '%s\t%s\n' "Yes, $action" "yes"
        } | "$ROFI" \
            -dmenu \
            -i \
            -sync \
            -p "$action?" \
            -mesg "Confirm action" \
            -display-columns 1 \
            -display-column-separator "$TAB" \
            -selected-row 0 \
            -theme-str "$CONFIRM_THEME"
    )

    [ "$(printf '%s' "$choice" | cut -f2)" = "yes" ]
}

require rofi

choice=$(
    {
        printf '%s\0icon\x1f%s\n' "Sleep" "power-sleep"
        printf '%s\0icon\x1f%s\n' "Lock" "power-lock"
        printf '%s\0icon\x1f%s\n' "Log out" "power-logout"
        printf '%s\0icon\x1f%s\n' "Reboot" "power-reboot"
        printf '%s\0icon\x1f%s\n' "Shutdown" "power-shutdown"
    } | menu
)

case "$choice" in
    *Sleep) action=sleep ;;
    *Lock) action=lock ;;
    *"Log out") action=logout ;;
    *Reboot) action=reboot ;;
    *Shutdown) action=shutdown ;;
    *) action= ;;
esac

case "$action" in
    lock)
        exec "$LOCK"
        ;;
    sleep)
        systemctl suspend
        ;;
    logout)
        confirm "Log out" && swaymsg exit
        ;;
    reboot)
        confirm "Reboot" && systemctl reboot
        ;;
    shutdown)
        confirm "Shutdown" && systemctl poweroff
        ;;
esac
